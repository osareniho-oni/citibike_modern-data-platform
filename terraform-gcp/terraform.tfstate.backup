            "resource_tags": {},
            "schema": "[{\"description\":\"Unique identifier of the station (UUID format)\",\"mode\":\"REQUIRED\",\"name\":\"station_id\",\"type\":\"STRING\"},{\"description\":\"Number of functional bikes currently at the station\",\"mode\":\"NULLABLE\",\"name\":\"num_bikes_available\",\"type\":\"INTEGER\"},{\"description\":\"Number of functional electric bikes currently at the station\",\"mode\":\"NULLABLE\",\"name\":\"num_ebikes_available\",\"type\":\"INTEGER\"},{\"description\":\"Number of disabled bikes currently at the station\",\"mode\":\"NULLABLE\",\"name\":\"num_bikes_disabled\",\"type\":\"INTEGER\"},{\"description\":\"Number of empty docks currently available for returning bikes\",\"mode\":\"NULLABLE\",\"name\":\"num_docks_available\",\"type\":\"INTEGER\"},{\"description\":\"Number of disabled docks at the station\",\"mode\":\"NULLABLE\",\"name\":\"num_docks_disabled\",\"type\":\"INTEGER\"},{\"description\":\"1 if the station is installed, 0 otherwise\",\"mode\":\"NULLABLE\",\"name\":\"is_installed\",\"type\":\"INTEGER\"},{\"description\":\"1 if the station is currently renting bikes, 0 otherwise\",\"mode\":\"NULLABLE\",\"name\":\"is_renting\",\"type\":\"INTEGER\"},{\"description\":\"1 if the station is currently accepting bike returns, 0 otherwise\",\"mode\":\"NULLABLE\",\"name\":\"is_returning\",\"type\":\"INTEGER\"},{\"description\":\"The last time this station reported its status (Unix timestamp in feed)\",\"mode\":\"NULLABLE\",\"name\":\"last_reported\",\"type\":\"TIMESTAMP\"},{\"description\":\"Number of scooters available\",\"mode\":\"NULLABLE\",\"name\":\"num_scooters_available\",\"type\":\"INTEGER\"},{\"description\":\"Number of scooters unavailable\",\"mode\":\"NULLABLE\",\"name\":\"num_scooters_unavailable\",\"type\":\"INTEGER\"},{\"description\":\"CitiBike legacy field for key availability\",\"mode\":\"NULLABLE\",\"name\":\"eightd_has_available_keys\",\"type\":\"BOOLEAN\"},{\"description\":\"The old numeric ID for the station\",\"mode\":\"NULLABLE\",\"name\":\"legacy_id\",\"type\":\"STRING\"},{\"description\":\"Raw message payload (required by Pub/Sub)\",\"mode\":\"NULLABLE\",\"name\":\"data\",\"type\":\"STRING\"},{\"description\":\"When the API last updated (from feed metadata)\",\"mode\":\"NULLABLE\",\"name\":\"api_last_updated\",\"type\":\"TIMESTAMP\"},{\"description\":\"When this record was ingested into BigQuery\",\"mode\":\"NULLABLE\",\"name\":\"ingestion_timestamp\",\"type\":\"TIMESTAMP\"}]",
